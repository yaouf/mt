{
  "name": "nms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx concurrently --kill-others \"redis-server\" \"next dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:db": "npm --prefix db run build",
    "knex:db": "npm --prefix db run knex",
    "dangerous:update:db": "npm --prefix db run dangerous:update",
    "test": "cross-env NODE_ENV=test ENV=test npm run dangerous:update:db && (npx concurrently --kill-others \"redis-server\" \"cross-env NODE_ENV=test ENV=test jest --verbose --detectOpenHandles --forceExit\"; npm run kill:redis || true)",
    "test:pw": "npx concurrently --kill-others \"redis-server\" \"cross-env NODE_ENV=test firebase emulators:start --project bdh-mobile-app---dev\" && (cross-env ENV=test NODE_ENV=test npm run dangerous:update:db && cross-env ENV=test NODE_ENV=test npx playwright test)",
    "test:all": "cross-env NODE_ENV=test npm run test:pw && npm run test",
    "test:all:debug": "cross-env NODE_ENV=test npm run test:pw -- --debug && npm run test",
    "kill:redis": "npx cross-port-killer 6379"
  },
  "dependencies": {
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "@heroicons/react": "^2.2.0",
    "@playwright/test": "^1.43.1",
    "bullmq": "^5.12.14",
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "expo-server-sdk": "^3.7.0",
    "firebase": "^10.13.1",
    "knex": "^3.1.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.45",
    "next": "^14.1.0",
    "oracledb": "^6.4.0",
    "pg-query-stream": "^4.5.3",
    "react": "^18",
    "react-aria": "^3.32.1",
    "react-aria-components": "^1.1.1",
    "react-datepicker": "^6.8.0",
    "react-dom": "^18",
    "tedious": "^18.6.2",
    "test-listen": "^1.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.24.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.2",
    "@types/cors": "^2.8.17",
    "@types/jest": "^29.5.12",
    "@types/node": "20.11.26",
    "@types/react": "18.2.65",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "cross-env": "^7.0.3",
    "cross-port-killer": "^1.4.0",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "firebase-admin": "^12.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next-test-api-route-handler": "^4.0.7",
    "node-mocks-http": "^1.14.1",
    "postcss": "^8",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.4",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "5.4.2"
  }
}
